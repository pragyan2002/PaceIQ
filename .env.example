# Notion — create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=               # Notion integration token (ntn_...)
NOTION_PARENT_PAGE_ID=        # Page ID under which DBs will be created

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=           # OpenRouter API key for the coaching agent

# Strava — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=             # From Strava API application
STRAVA_CLIENT_SECRET=         # From Strava API application
STRAVA_REFRESH_TOKEN=         # Obtained via OAuth2 flow (see README)

# Sync config
STRAVA_SYNC_DAYS=30           # How many days back to import on first sync

# Notion DB IDs — populated after running `npm run setup`
NOTION_RUNS_DB_ID=            # Created by setup script
NOTION_LOG_DB_ID=             # Created by setup script
NOTION_RACES_DB_ID=           # Created by setup script
NOTION_SESSIONS_DB_ID=        # Created by setup script
